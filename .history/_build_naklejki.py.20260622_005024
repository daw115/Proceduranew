# ── konwersja HTML procedur → tekst / markup ───────────────────────────────
def html_to_text(s):
    if not s: return ''
    s = s.replace('&nbsp;', ' ')
    s = re.sub(r'<br\s*/?>', '\n', s, flags=re.I)
    s = re.sub(r'</(p|div|li)>', '\n', s, flags=re.I)
    s = re.sub(r'<li[^>]*>', '• ', s, flags=re.I)
    s = re.sub(r'<[^>]+>', '', s)
    s = htmlmod.unescape(s)
    s = re.sub(r'[ \t]+', ' ', s)
    s = re.sub(r'\n{3,}', '\n\n', s)
    return s.strip()

def html_to_rl(s):
    """HTML → markup akceptowany przez reportlab Paragraph (<b>,<i>,<br/>)."""
    if not s: return ''
    s = s.replace('&nbsp;', ' ')
    s = re.sub(r'<strong>', '<b>', s, flags=re.I)
    s = re.sub(r'</strong>', '</b>', s, flags=re.I)
    s = re.sub(r'<em>', '<i>', s, flags=re.I)
    s = re.sub(r'</em>', '</i>', s, flags=re.I)
    s = re.sub(r'<br\s*/?>', '<br/>', s, flags=re.I)
    s = re.sub(r'<li[^>]*>', '<br/>• ', s, flags=re.I)
    s = re.sub(r'</(p|div|ul|ol)>', '<br/>', s, flags=re.I)
    s = re.sub(r'<(?!/?(b|i|br|font)[ />])[^>]*>', '', s)  # usuń pozostałe tagi
    # napraw & (poza encjami)
    s = re.sub(r'&(?!amp;|lt;|gt;|#)', '&amp;', s)
    s = re.sub(r'(<br/>)+', '<br/>', s)
    s = re.sub(r'^(<br/>)+', '', s)
    return s.strip()

# ── formatowanie procedur/opisów wg wzoru staticHints (hierarchia bulletów) ──
def format_proc(text):
    """Rozkłada tekst na hierarchię (level, tekst, header) jak w staticHints:
       0 = nagłówek/lead-in, 1 = punkt •, 2 = zagnieżdżony 'kod NN'."""
    if not text: return []
    t = re.sub(r'[ \t]*\n[ \t]*', ' ', str(text)).strip()
    t = re.sub(r'\s+', ' ', t)
    t = re.sub(r'\s*(Jeżeli:)', r' ‖\1', t)        # 'Jeżeli:' jako osobny nagłówek
    parts = t.split('•')
    lead = parts[0].strip()
    items = [p.strip() for p in parts[1:] if p.strip()]
    out = []
    for seg in re.split(r'‖', lead):
        seg = seg.strip()
        if seg:
            out.append((0, seg, seg.endswith(':')))
    for it in items:
        sub = re.split(r'‖', it)
        main = sub[0].strip()
        lvl = 2 if re.match(r'^kod\s', main, re.I) else 1
        if main:
            out.append((lvl, main, False))
        for extra in sub[1:]:
            extra = extra.strip()
            if extra:
                out.append((0, extra, extra.endswith(':')))
    return out

def _esc_rl(s):
    s = htmlmod.escape(str(s))
    return s

def proc_to_rl(text):
    """Hierarchia procedury → markup reportlab (nagłówki <b>, bullety, wcięcia)."""
    parts = format_proc(text)
    if not parts:
        return '—'
    lines = []
    for lvl, txt, hdr in parts:
        body = _esc_rl(txt)
        # podświetl odnośniki [Rxx — pełny opis]
        body = re.sub(r'\[(R\d+[^\]]*)\]', r'<font color="#1F4E78">[\1]</font>', body)
        if hdr:
            lines.append(f'<b>{body}</b>')
        elif lvl == 1:
            lines.append(f'• {body}')
        elif lvl == 2:
            lines.append(f'&nbsp;&nbsp;&nbsp;&nbsp;– {body}')
        else:
            lines.append(body)
    return '<br/>'.join(lines)

