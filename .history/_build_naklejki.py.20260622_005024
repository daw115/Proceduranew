TILE_SPEC = {
    'zielony':         ('#00B050', '',  '#FFFFFF', None),
    'zielony R':       ('#00B050', 'R', '#FFFFFF', None),
    'ciemnozielony W': ('#2E7D32', 'W', '#FFFFFF', None),
