# ── parser bazy ryzyk (Ryzyka_pelna_baza_IDCC.html) → kotwice #Rxx w PDF ────
def parse_risks():
    src = ROOT / 'Ryzyka_pelna_baza_IDCC.html'
    if not src.exists():
        return []
    html = src.read_text(encoding='utf-8')
    parts = re.split(r'<div class="risk(?: critical)?" id="(R\d+)">', html)
    risks = []
    for i in range(1, len(parts), 2):
        rid = parts[i]
        body = parts[i+1].split('<div class="risk')[0].split('<div class="group-header"')[0]
        def block(cls):
            m = re.search(r'<div class="'+cls+r'">(.*?)</div>', body, re.S)
            return clean_html(m.group(1)) if m else ''
        h3 = re.search(r'<h3>(.*?)</h3>', body, re.S)
        title = clean_html(h3.group(1)) if h3 else rid
        meta = re.search(r'<div class="risk-meta">(.*?)</div>', body, re.S)
        meta_t = clean_html(meta.group(1)) if meta else ''
        # treść główna: wszystko poza meta/screen-caption/h3 (procedura, tabele, shortcut)
        main = body
        main = re.sub(r'<h3>.*?</h3>', '', main, flags=re.S)
        main = re.sub(r'<div class="risk-meta">.*?</div>', '', main, flags=re.S)
        main = re.sub(r'<div class="screen-caption">.*?</div>', '', main, flags=re.S)
        risks.append({'id': rid, 'title': title, 'meta': meta_t,
                      'impact': block('impact'), 'shortcut': block('shortcut'),
                      'body': clean_html(main)})
    return risks

def clean_html(s):
    if not s: return ''
    s = re.sub(r'<br\s*/?>', '\n', s, flags=re.I)
    s = re.sub(r'</(p|div|li|tr|h[1-6])>', '\n', s, flags=re.I)
    s = re.sub(r'<li[^>]*>', '• ', s, flags=re.I)
    s = re.sub(r'<td[^>]*>', '  ', s, flags=re.I)
    s = re.sub(r'<[^>]+>', '', s)
    s = htmlmod.unescape(s)
    s = re.sub(r'[ \t]+', ' ', s)
    s = re.sub(r'\n[ \t]+', '\n', s)
    s = re.sub(r'\n{2,}', '\n', s)
    return s.strip()

