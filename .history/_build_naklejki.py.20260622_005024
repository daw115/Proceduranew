# 3) Named destinations w info.pdf (żeby info.pdf#KOD działało w przeglądarce)
# ═══════════════════════════════════════════════════════════════════════════
def add_named_dests():
    from pypdf import PdfReader, PdfWriter
    src = CCM/'info.pdf'
    r = PdfReader(str(src))
    w = PdfWriter(clone_from=str(src))
    added = 0
    def walk(items):
        nonlocal added
        for item in items:
            if isinstance(item, list):     # zagnieżdżone — rekurencyjnie
                walk(item); continue
            w.add_named_destination(item.title, r.get_destination_page_number(item))
            added += 1
    walk(r.outline)
    with open(src, 'wb') as f:
        w.write(f)
    chk = PdfReader(str(src)).named_destinations
    print(f'Named destinations dodane: {added} | w pliku: {len(chk)}')
    for t in ['FID1_831','PERUN_ID3_ATC','R05','R18','R20','ryzyka']:
        print(f'   #{t:16} {"OK" if t in chk else "BRAK"}')

add_named_dests()
