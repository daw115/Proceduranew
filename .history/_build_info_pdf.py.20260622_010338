def build():
    parts = ['<!DOCTYPE html><html lang="pl"><head><meta charset="utf-8">',
             f'<style>{CSS}</style></head><body>']
    # cover
    parts.append('''<div class="cover">
      <div class="logo">PSE</div><div class="sub">Polskie Sieci Elektroenergetyczne</div>
      <h1>CCM — Pulpit dyspozytorski IDCC<br>Naklejki informacyjne i baza ryzyk</h1>
      <div class="lead">Opis plików, pełny katalog stanów kafelków oraz baza ryzyk operacyjnych.
      Kotwice: /assets/info.pdf#KOD oraz /assets/info.pdf#R05.</div>
      <div class="tags"><b>71 plików</b><b>1414 stanów</b><b>29 ryzyk</b></div>
    </div>''')
    # naklejki
    for code in B.ANCHORS:
        parts.append(naklejka_html(code))
    # ryzyka
    risks = B.parse_risks()
    parts.append('<h2 class="section-title" id="ryzyka">Ryzyka — pełna baza IDCC</h2>')
    for rk in risks:
        parts.append(risk_html(rk))
    parts.append('</body></html>')
    html = '\n'.join(parts)

    out = CCM / 'info.pdf'
    weasyprint.HTML(string=html, base_url=str(ROOT)).write_pdf(str(out))
    # weryfikacja kotwic
    from pypdf import PdfReader
    nd = PdfReader(str(out)).named_destinations
    rs = sum(1 for k in nd if k.startswith('R') and k[1:].isdigit())
    print(f'PDF: {out}  ({out.stat().st_size:,} B)')
    print(f'Named destinations: {len(nd)} | naklejki+ryzyka | '
          f'FID1_831={"FID1_831" in nd} R05={"R05" in nd} ryzyk={rs}')

if __name__ == '__main__':
    build()
