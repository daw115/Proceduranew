ACTION_RE = re.compile(
    r'(→|\bgdy\b|sprawdź|pobierz|wyślij|manual upload|zgłoś|weryfik|zweryfik|'
    r'ustaw|podnieś|telefon|diagnost|wgraj|wygeneruj|reaguj|ponów|'
    r'oznacz|odczytaj|przejdź|otwórz|\bstop\b)', re.I)

ROOT = B.ROOT
CCM  = B.CCM

def esc(s): return H.escape(str(s or ''))

def decorate(s):
    """Na już zaescapowanym tekście: brzydkie odnośniki → czyste, klikalne linki
       wewnątrz PDF; usuwa kody węzłów [Nxx] i numerki."""
    s = re.sub(r'\[?\s*R(\d+)\s*—\s*pełny opis\s*\]?',
               r'<a class="rlink" href="#R\1">pełny opis ryzyka</a>', s)
    s = re.sub(r'Szczegóły \(opis \+ screeny\):\s*R(\d+)(?:\s*·\s*R\d+)*',
               r'<a class="rlink" href="#R\1">szczegóły z opisem i zrzutami ekranu</a>', s)
    s = re.sub(r'\bR(\d+)(?:\s*·\s*R\d+)+',
               r'<a class="rlink" href="#R\1">powiązane ryzyka</a>', s)
    s = re.sub(r'\s*\[[NP]\d+\]', '', s)                       # kody węzłów
    s = re.sub(r'\bStan \d+\s*\(([^)]+)\)', r'stan \1', s)     # odnośniki do stanów
    s = re.sub(r'(→\s*)Stan \d+\b', r'\1powiązany stan', s)
    s = re.sub(r'\bStan \d+\b', 'powiązany stan', s)
    s = re.sub(r'HTML §[\d.]+:?\s*', '', s)                    # znacznik HTML §
    return s

# ── kafelki jako wektorowe spany (z TILE_SPEC) ─────────────────────────────
def tile_css():
    out = []
    for color, (fill, mark, mcol, border) in B.TILE_SPEC.items():
        cls = 'tl-' + color.replace(' ', '_').replace('!', 'x').replace('?', 'q')
        bd = f'border:2px solid {border};' if border else f'border:1px solid {fill};'
        out.append(f'.{cls}{{background:{fill};color:{mcol};{bd}}}')
    return '\n'.join(out)

def tile(color):
    spec = B.TILE_SPEC.get((color or '').strip())
    if not spec:
        spec = B.TILE_SPEC['puste']
        color = 'puste'
    cls = 'tl-' + color.strip().replace(' ', '_').replace('!', 'x').replace('?', 'q')
    return f'<span class="tile {cls}">{esc(spec[1])}</span>'

def stan_html(stan_text):
    pairs = B.parse_stan(stan_text)
    if not pairs:
        return f'<span class="muted">{esc(stan_text or "—")}</span>'
    rows = ''.join(
        f'<div class="kf"><span class="kf-lab">{esc(col)}</span>{tile(clr)}</div>'
        for col, clr in pairs)
    return f'<div class="kf-wrap">{rows}</div>'

# ── procedury/opisy → hierarchiczny HTML (wzór staticHints) ────────────────
def proc_html(text):
    parts = B.format_proc(text)
    if not parts:
        return '<span class="muted">—</span>'
    html, stack = [], []   # stack: lista otwartych poziomów (1/2)
    def close_to(level):
        while stack and stack[-1] >= level:
            html.append('</li></ul>')
            stack.pop()
    for lvl, txt, hdr in parts:
        body = decorate(esc(txt))
        if hdr or lvl == 0:
            close_to(1)
            html.append(f'<div class="p-hdr">{body}</div>' if hdr else f'<div class="p-line">{body}</div>')
        elif lvl == 1:
            close_to(1)
            html.append(f'<ul class="p-ul"><li>{body}')
            stack.append(1)
        elif lvl == 2:
            if not stack:
                html.append('<ul class="p-ul"><li>'); stack.append(1)
            close_to(2)
            html.append(f'<ul class="p-sub"><li>{body}')
            stack.append(2)
    close_to(1)
    return ''.join(html)

def is_passive(text):
    t = B.html_to_text(text)
    return ('•' not in t) and not ACTION_RE.search(t)

def proc_block(text):
    if is_passive(text):
        return f'<div class="p-ok">{decorate(esc(B.html_to_text(text)))}</div>'
    return proc_html(text)

# ── sekcja: naklejka ───────────────────────────────────────────────────────
def naklejka_html(code):
    m = B.meta(code)
    st = B.variant_for(code) or []
    rows = ''
    for s in st:
        rows += (f'<tr><td class="c-nr">{esc(s.get("nr",""))}</td>'
                 f'<td class="c-st">{stan_html(s.get("stan",""))}</td>'
                 f'<td class="c-op">{esc(B.html_to_text(s.get("opis_stanu","")))}</td>'
                 f'<td class="c-pr">{proc_block(s.get("procedura",""))}</td></tr>')
    cat = (f'<h4 class="sec-h">Katalog stanów kafelków '
           f'<span class="badge">{len(st)}</span></h4>'
           f'<table class="cat"><thead><tr>'
           f'<th class="c-nr">#</th><th class="c-st">Stan kafelków</th>'
           f'<th class="c-op">Opis stanu</th><th class="c-pr">Procedury awaryjne</th>'
           f'</tr></thead><tbody>{rows}</tbody></table>') if st else (
           '<p class="muted">Dla tego pliku katalog stanów nie jest zdefiniowany odrębnie '
           '— monitorowanie zgodnie z profilem i procedurą główną.</p>')
    return f'''<section class="page nk" id="{esc(code)}">
  <div class="nk-head">
    <div class="nk-code">{esc(code)}</div>
    <div class="nk-name">{esc(m["nazwa"])}<span class="nk-area">{esc(m["obszar"])}</span></div>
  </div>
  <div class="meta">
    <div class="mi"><span>Profil</span><b>{esc(m["profil"])}</b></div>
    <div class="mi"><span>Target End Time</span><b>{esc(m["tet"])}</b></div>
    <div class="mi"><span>Critical End Time</span><b>{esc(m["cet"])}</b></div>
    <div class="mi"><span>Wersja</span><b>{esc(m["wersja"])}</b></div>
    <div class="mi"><span>Źródło</span><b>{esc(m["zrodlo"])}</b></div>
  </div>
  <div class="cards">
    <div class="card"><h5>Opis pliku</h5><p>{esc(B.html_to_text(m["opis"]))}</p></div>
    <div class="card"><h5>Ścieżka pliku</h5><p>{esc(B.html_to_text(m["sciezka"]))}</p></div>
    <div class="card"><h5>Kontakt w przypadku awarii</h5><p>{esc(B.html_to_text(m["kontakt"]))}</p></div>
  </div>
  {cat}
</section>'''

# ── sekcja: ryzyko ─────────────────────────────────────────────────────────
def risk_html(rk):
    impact = (rk['impact'].replace('Wpływ na IDCC:', '').strip()) if rk['impact'] else ''
    body_parts = [p.strip() for p in (rk['body'] or '').split('\n')
                  if p.strip() and not p.strip().startswith('Wpływ na IDCC')]
    body = ''.join(f'<p>{esc(p)}</p>' for p in body_parts)
    blocks = ''
    if impact:
        blocks += f'<div class="callout"><h5>Wpływ na IDCC</h5><p>{esc(impact)}</p></div>'
    if body:
        blocks += f'<h5 class="sec-h">Postępowanie</h5>{body}'
    if rk['shortcut']:
        blocks += f'<div class="card shortcut"><h5>Skrót</h5><p>{esc(rk["shortcut"])}</p></div>'
    return f'''<section class="page risk" id="{esc(rk["id"])}">
  <div class="rk-head"><span class="rk-id">{esc(rk["id"])}</span>
    <span class="rk-title">{esc(rk["title"].split("—",1)[-1].strip())}</span></div>
  {f'<div class="rk-meta">{esc(rk["meta"])}</div>' if rk['meta'] else ''}
  {blocks}
</section>'''

