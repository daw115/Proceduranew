"""Generuje staticHints (TS) dla WSZYSTKICH plikГіw вҖ” w formacie pliku-wzoru
   CCM/staticHints-przyklad-dla-FID1-831.txt.

Е№rГіdЕӮa:
  Stany_kafelkow_per_plik_IDCC.xlsx   вҖ” stany per kod (markery + fill = kafelek),
                                         peЕӮne ramki (sytuacja, procedury, opisвҖҰ)
  CCM/staticHints-przyklad-dla-FID1-831.txt вҖ” wzГіr formatu + enumy AC (do walidacji
                                         i tabeli sygnatur wierszy dla profilu 2CCT)

Mapowanie kafelek вҶ’ DashboardItemStatus:
  вҖў 8 kombinacji (marker,fill) jednoznacznych вҖ” wprost.
  вҖў wieloznaczne (czerwony/fioletowy/czarny bez markera) вҶ’ tabela sygnatur caЕӮego
    wiersza wyprowadzona z AC (dokЕӮadna dla 2CCT/3COL o tych samych sygnaturach),
    z fallbackiem per-cela.
  вҖў pomaraЕ„czowy (zbliЕјa siДҷ TET) i szaryвҖ‘? вҖ” brak w pliku-wzorze вҶ’ oznaczone /*?*/
    do potwierdzenia z definicjД… enuma w programie.

WyjЕӣcie: CCM/staticHints-IDCC-all.txt
"""
import re
from pathlib import Path
from openpyxl import load_workbook

ROOT = Path('/Volumes/SSD/CLAUDE_WORK/Procedura')
CCM  = ROOT / 'CCM'
XLSX = ROOT / 'Stany_kafelkow_per_plik_IDCC.xlsx'
SAMPLE = CCM / 'staticHints-przyklad-dla-FID1-831.txt'

SHEETS = ['AC 831 (2CCT)','GLSK CBCORA 607-617 (2CCT)','ATC 928 (zwrotny)',
          'IVA 710 (3COL)','Paczki PERUN (2MS)','Skladowe MinIO (MIN)',
          'sFTP-ZP NTC MD250 IGM (SFTP)']
COLNAME = {1:'CCtool wysЕӮ.', 2:'CCtool zwalid.', 3:'MinIO', 4:'sFTP/ZP wysЕӮ.'}

# в”Җв”Җ per-cela: (marker, fill) вҶ’ DashboardItemStatus в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Mapowanie 1:1 wg OFICJALNEJ legendy enumГіw programu (kafelek вҶ’ status):
CELL_ENUM = {
    ('В·','00FFFFFF'):'UNKNOWN',            # 1  biaЕӮe/puste
    ('В·','00BFBFBF'):'UNKNOWN',            # 1  szary
    ('В·','00C00000'):'FAILURE',            # 2  czerwony
    ('В·','0000B050'):'SUCCESS',            # 3  zielony
    ('R','0000B050'):'FORCEDSUCCESS',      # 4  zielony R
    ('W','002E7D32'):'SENTMANUALLY',       # 5  ciemnozielony W
    ('WвҶ‘CET','001B5E20'):'SENTMANUALLYAFTERCET',  # 6  W po CET
    ('?','00C00000'):'ACKNOTRECEIVED',     # 7  czerwony ?
    ('В·','00ED7D31'):'WARNING',            # 8  pomaraЕ„czowy
    ('В·','00000000'):'EXCEEDED',           # 9  czarny
    ('!','00C00000'):'FILESIZEBAD',        # 10 czerwony !
    ('?','00BFBFBF'):'PROCESSRUNNING',     # 11 szary ?
    ('В·','007030A0'):'CONN_AFTER_CET',     # 12 fioletowy
}
FLAG_COMBO = set()   # brak вҖ” mapowanie peЕӮne wg legendy

def cellkey(c):
    if c is None: return None
    if str(c.value) == 'вҖ”': return None
    if not (c.fill and c.fill.patternType): return None   # brak wypeЕӮnienia = kolumna nieaktywna
    fill = c.fill.fgColor.rgb
    if fill is None: return None
    m = 'В·' if c.value in (None,'None','') else str(c.value)
    return (m, fill)

# в”Җв”Җ tabela sygnatur wierszy z AC (exact dla 2CCT) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
def load_ac_signatures():
    txt = SAMPLE.read_text(encoding='utf-8')
    blocks = re.split(r'\n\s*\{\s*\n\s*status:', txt)[1:]
    enums = [re.findall(r"DashboardItemStatus\.([A-Z_]+)", b) for b in blocks]
    wb = load_workbook(XLSX)
    rows = [r for r in wb['AC 831 (2CCT)'].iter_rows(min_row=2) if r[0].value=='FID1-831']
    sig = {}
    for i, r in enumerate(rows):
        key = tuple(cellkey(r[ci]) for ci in (1,2,3,4) if cellkey(r[ci]))
        if i < len(enums):
            sig[key] = tuple(enums[i])
    return sig

AC_SIG = load_ac_signatures()

def row_enums(cells):
    """cells: lista (colName, cellkey) tylko aktywnych kolumn вҶ’ lista enumГіw.
       SpГіjnie: enum per-cela dla kaЕјdej aktywnej kolumny."""
    return [CELL_ENUM.get(ck, 'UNKNOWN') for _, ck in cells]

# в”Җв”Җ parser peЕӮnej ramki в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
FRAME_SECTIONS = ['Stan kafelkГіw','Opis stanu kafelkГіw','Procedury awaryjne',
                  'Kafelek MinIO / sFTP','Opis pliku','ЕҡcieЕјka pliku',
                  'Kontakt w przypadku awarii']
def parse_frame(text):
    if not text: return {}
    text = text.replace('\r\n','\n')
    body = '\n'.join(text.split('\n')[1:])
    idx = []
    for sec in FRAME_SECTIONS:
        for mm in re.finditer(r'(?m)^'+re.escape(sec)+r'\s*$', body):
            idx.append((mm.start(), mm.end(), sec))
    idx.sort()
    rec = {}
    for i,(s,e,sec) in enumerate(idx):
        nxt = idx[i+1][0] if i+1 < len(idx) else len(body)
        rec[sec] = body[e:nxt].strip()
    return rec

def inline(s):
    """Zwija wielowierszowy tekst do jednej linii (styl wzoru: bullety przez spacje)."""
    s = re.sub(r'[ \t]*\n[ \t]*', ' ', str(s or '')).strip()
    return re.sub(r'\s+', ' ', s)

def q(s):
    """Escape do literaЕӮu w pojedynczych cudzysЕӮowach (TS)."""
    return str(s or '').replace('\\', '\\\\').replace("'", "\\'")

# akcja ratunkowa = to faktyczna procedura (zostaje inline); jej brak = HTML <strong>
ACTION_RE = re.compile(
    r'(вҶ’|\bgdy\b|sprawdЕә|pobierz|wyЕӣlij|manual upload|zgЕӮoЕӣ|weryfik|zweryfik|'
    r'ustaw|podnieЕӣ|telefon|diagnost|wgraj|wygeneruj|reaguj|ponГіw|'
    r'oznacz|odczytaj|przejdЕә|otwГіrz|\bstop\b)', re.I)

# narzДҷdzia/wДҷzЕӮy вҶ’ czytelne hiperЕӮД…cza do inwentarza (najdЕӮuЕјsze dopasowania pierwsze)
TOOL_LINKS = [
    ('Core CC Tool (Manual Upload)', 'Inwentarz_IDCC.html#P01'),
    ('Manual Upload',                'Inwentarz_IDCC.html#P01'),
    ('Message Viewer',               'Inwentarz_IDCC.html#N02'),
    ('Core CC Tool',                 'Inwentarz_IDCC.html#N02'),
    ('Connector 2.0',                'Inwentarz_IDCC.html#N05'),
    ('Perun4V',                      'Inwentarz_IDCC.html#N03'),
    ('aplikacji ZP',                 'Inwentarz_IDCC.html#N06'),
    ('Kreator',                      'Inwentarz_IDCC.html#N08'),
    ('MinIO',                        'Inwentarz_IDCC.html#N04'),
    ('RCC',                          'Inwentarz_IDCC.html#N13'),
    ('CCM',                          'Inwentarz_IDCC.html#N01'),
]

def linkify(t):
    """Czytelne odnoЕӣniki do ryzyk; usuwa numerki/dziwne nawiasy.
       NIE linkuje narzДҷdzi вҖ” CCM nie hostuje Inwentarz_IDCC.html (zostaje czysty tekst)."""
    # ryzyka вҶ’ czytelny link (bez numerkГіw i nawiasГіw [])
    t = re.sub(r'SzczegГіЕӮy \(opis \+ screeny\):\s*R\d+(?:\s*В·\s*R\d+)*',
               '<a href="Ryzyka_pelna_baza_IDCC.html" target="_blank">'
               'szczegГіЕӮy z opisem i zrzutami ekranu</a>', t)
    t = re.sub(r'\[?\s*R(\d+)\s*вҖ”\s*peЕӮny opis\s*\]?',
               lambda m: f'<a href="Ryzyka_pelna_baza_IDCC.html#R{m.group(1)}" '
                         f'target="_blank">peЕӮny opis ryzyka</a>', t)
    t = re.sub(r'\bR(\d+)(?:\s*В·\s*R\d+)+',
               lambda m: f'<a href="Ryzyka_pelna_baza_IDCC.html#R{m.group(1)}" '
                         f'target="_blank">powiД…zane ryzyka</a>', t)
    # odnoЕӣniki do innych stanГіw вҶ’ czytelnie, bez numerkГіw
    t = re.sub(r'\bStan \d+\s*\(([^)]+)\)', r'stan \1', t)
    t = re.sub(r'(вҶ’\s*)Stan \d+\b', r'\1powiД…zany stan', t)
    t = re.sub(r'\bStan \d+\b', 'powiД…zany stan', t)
    # znacznik вҖһHTML В§x.x" вҶ’ usuЕ„ (zostaw opis)
    t = re.sub(r'HTML В§[\d.]+:?\s*', '', t)
    return t

def linkify_path(t):
    """ЕҡcieЕјka pliku: 'Nazwa [N06] вҶ’ вҖҰ' вҶ’ czytelne hiperЕӮД…cza (bez [Nxx])."""
    def repl(m):
        name = m.group(1).strip()
        return f'<a href="Inwentarz_IDCC.html#{m.group(2)}" target="_blank">{name}</a>'
    t = re.sub(r'([^вҶ’+/\[\]]+?)\s*\[([NP]\d+)\]', repl, inline(t))
    return re.sub(r'(вҶ’|\+|/)\s*(<a )', r'\1 \2', t)   # odstДҷp po separatorze

def proc_field(text):
    """emergencyProcedures: pasywne (вҖһBrak dziaЕӮaЕ„"/вҖһMonitoring"/вҖһвҖҰOK") вҶ’ <strong>вҖҰ</strong>;
       procedury (kroki 'вҖў' lub instrukcja) вҶ’ inline; wszДҷdzie czytelne hiperЕӮД…cza."""
    t = linkify(inline(text))
    plain = re.sub(r'<[^>]+>', '', t)
    if 'вҖў' in plain or ACTION_RE.search(plain):
        return t
    return f'<strong>{t}</strong>'

# в”Җв”Җ budowa pliku в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
def build():
    wb = load_workbook(XLSX)
    # zbierz stany per kod (zachowujД…c kolejnoЕӣДҮ i przypisanie do arkusza)
    order = []   # lista kodГіw w kolejnoЕӣci pierwszego wystД…pienia
    states = {}  # kod -> lista (row, sheet)
    flagged = 0; total_states = 0
    for shn in SHEETS:
        for r in wb[shn].iter_rows(min_row=2):
            if not r[0].value: continue
            code = str(r[0].value).strip()
            if code not in states:
                states[code] = []; order.append(code)
            states[code].append(r)

    out = []
    out.append('  private staticHints: Record<string, Hint[]> = {')
    for ci, code in enumerate(order):
        out.append(f"    '{code}': [")
        for r in states[code]:
            total_states += 1
            fr = parse_frame(r[5].value)
            # aktywne kolumny + enumy
            active = [(COLNAME[c], cellkey(r[c])) for c in (1,2,3,4) if cellkey(r[c])]
            enums = row_enums(active)
            out.append('      {')
            out.append('        status: [')
            for (cn, ck), en in zip(active, enums):
                flag = '  /*? potwierdЕә enum*/' if ck in FLAG_COMBO else ''
                if ck in FLAG_COMBO: flagged += 1
                out.append(f"          {{ colName: '{cn}', status: DashboardItemStatus.{en} }},{flag}")
            # usuЕ„ ostatni przecinek w bloku status
            if out[-1].rstrip().endswith(','):
                out[-1] = out[-1].rstrip()[:-1] if '/*?' not in out[-1] else out[-1]
            out.append('        ],')
            out.append(f"        situationDescription: '{q(inline(fr.get('Opis stanu kafelkГіw','')))}',")
            out.append(f"        emergencyProcedures: '{q(proc_field(fr.get('Procedury awaryjne','')))}',")
            out.append(f"        minioSftp: '{q(linkify(inline(fr.get('Kafelek MinIO / sFTP',''))))}',")
            out.append(f"        fileDesc: '{q(inline(fr.get('Opis pliku','')))}',")
            out.append(f"        filePath: '{q(linkify_path(fr.get('ЕҡcieЕјka pliku','')))}'")
            out.append('      },')
        out.append('    ],')
    out.append('  }')
    text = '\n'.join(out) + '\n'

    dst = CCM / 'staticHints-IDCC-all.txt'
    dst.write_text(text, encoding='utf-8')
    print(f'Zapisano: {dst}')
    print(f'KodГіw (kluczy): {len(order)} | stanГіw ЕӮД…cznie: {total_states} | '
          f'oznaczonych /*?*/: {flagged}')
    return dst

# в”Җв”Җ walidacja enumГіw na AC (musi byДҮ 100%) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
def validate():
    txt = SAMPLE.read_text(encoding='utf-8')
    blocks = re.split(r'\n\s*\{\s*\n\s*status:', txt)[1:]
    exp = [re.findall(r"DashboardItemStatus\.([A-Z_]+)", b) for b in blocks]
    wb = load_workbook(XLSX)
    rows = [r for r in wb['AC 831 (2CCT)'].iter_rows(min_row=2) if r[0].value=='FID1-831']
    # dokЕӮadnoЕӣДҮ per-enum: porГіwnaj enum dla kaЕјdej kolumny, ktГіrД… wzГіr wymienia
    tot = hit = 0
    arr_ok = 0
    for i, r in enumerate(rows):
        active = [(COLNAME[c], cellkey(r[c])) for c in (1,2,3,4) if cellkey(r[c])]
        got = row_enums(active)
        gmap = {cn: e for (cn, _), e in zip(active, got)}
        # mapa oczekiwana per colName ze wzoru
        b = blocks[i]
        ecols = re.findall(r"colName:\s*'([^']+)',\s*status:\s*DashboardItemStatus\.([A-Z_]+)", b)
        all_match = True
        for cn, en in ecols:
            tot += 1
            if gmap.get(cn) == en: hit += 1
            else: all_match = False
        if all_match and ecols: arr_ok += 1
    print(f'Walidacja AC вҖ” dokЕӮadnoЕӣДҮ per-enum: {hit}/{tot} ({100*hit//tot}%) | '
          f'stany w peЕӮni zgodne: {arr_ok}/{len(rows)}')
    return hit, tot

if __name__ == '__main__':
    print('== walidacja mapowania na wzorze AC ==')
    validate()
    print('== generacja ==')
    build()
