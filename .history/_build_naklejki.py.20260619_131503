from docx import Document
from docx.shared import Pt, Cm, RGBColor
from docx.enum.text import WD_BREAK
from docx.enum.table import WD_TABLE_ALIGNMENT
from docx.oxml.ns import qn
from docx.oxml import OxmlElement

PSE_BLUE = RGBColor(0x1F, 0x4E, 0x78)

def add_bookmark(paragraph, name):
    """Wstrzykuje zakładkę Word o nazwie = name wokół akapitu (dla #anchor po eksporcie)."""
    start = OxmlElement('w:bookmarkStart')
    start.set(qn('w:id'), str(abs(hash(name)) % 100000))
    start.set(qn('w:name'), name)
    end = OxmlElement('w:bookmarkEnd')
    end.set(qn('w:id'), str(abs(hash(name)) % 100000))
    p = paragraph._p
    p.insert(0, start)
    p.append(end)

def shade(cell, hexclr):
    tcPr = cell._tc.get_or_add_tcPr()
    shd = OxmlElement('w:shd'); shd.set(qn('w:val'),'clear'); shd.set(qn('w:fill'),hexclr)
    tcPr.append(shd)

def set_borders(tbl):
    tblPr = tbl._tbl.tblPr
    b = OxmlElement('w:tblBorders')
    for edge in ('top','left','bottom','right','insideH','insideV'):
        e = OxmlElement(f'w:{edge}')
        e.set(qn('w:val'),'single'); e.set(qn('w:sz'),'4'); e.set(qn('w:color'),'A8B8C8')
        b.append(e)
    tblPr.append(b)

def build_docx():
    doc = Document()
    # marginesy A4
    sec = doc.sections[0]
    sec.page_width, sec.page_height = Cm(21), Cm(29.7)
    sec.left_margin = sec.right_margin = Cm(1.8)
    sec.top_margin = sec.bottom_margin = Cm(1.6)
    base = doc.styles['Normal']
    base.font.name = 'Calibri'; base.font.size = Pt(10)

    # strona tytułowa
    t = doc.add_paragraph(); r = t.add_run('CCM — Naklejki informacyjne IDCC')
    r.bold = True; r.font.size = Pt(20); r.font.color.rgb = PSE_BLUE
    s = doc.add_paragraph().add_run(
        'Załącznik info.pdf — pełny opis plików i katalog stanów kafelków. '
        'Każdy nagłówek = kotwica: /assets/info.pdf#KOD (np. info.pdf#FID1_831).')
    s.font.size = Pt(10); s.italic = True
    note = doc.add_paragraph().add_run(
        'Eksport do PDF: zaznacz opcję „Utwórz zakładki przy użyciu: Nagłówki / Zakładki programu Word", '
        'aby nazwy nagłówków stały się kotwicami. W nazwach używaj wyłącznie liter, cyfr i podkreśleń '
        '(myślniki nie działają jako kotwice).')
    note.font.size = Pt(9); note.font.color.rgb = RGBColor(0x88,0x55,0x00)
    doc.add_paragraph().add_run().add_break(WD_BREAK.PAGE)

    for ci, code in enumerate(ANCHORS):
        m = meta(code)
        # H1 = kotwica (TEKST = KOD)
        h = doc.add_heading(level=1)
        run = h.add_run(code)
        run.font.color.rgb = PSE_BLUE
        add_bookmark(h, code)
        # podtytuł
        sub = doc.add_paragraph()
        rr = sub.add_run(f'{m["nazwa"]}  —  {m["obszar"]}')
        rr.italic = True; rr.font.size = Pt(11); rr.font.color.rgb = RGBColor(0x44,0x44,0x44)

        # meta tabela
        mt = doc.add_table(rows=2, cols=5); mt.alignment = WD_TABLE_ALIGNMENT.LEFT
        set_borders(mt)
        hdr = ['Profil','Target End Time','Critical End Time','Wersja','Źródło']
        val = [m['profil'], m['tet'], m['cet'], str(m['wersja']), m['zrodlo']]
        for j,(hh,vv) in enumerate(zip(hdr,val)):
            c0 = mt.rows[0].cells[j]; c0.text = hh; shade(c0,'1F4E78')
            for p in c0.paragraphs:
                for rn in p.runs: rn.bold=True; rn.font.size=Pt(9); rn.font.color.rgb=RGBColor(255,255,255)
            c1 = mt.rows[1].cells[j]; c1.text = vv
            for p in c1.paragraphs:
                for rn in p.runs: rn.font.size=Pt(9)

        def section(title, body):
            ph = doc.add_paragraph(); rh = ph.add_run(title)
            rh.bold=True; rh.font.size=Pt(10.5); rh.font.color.rgb=PSE_BLUE
            ph.paragraph_format.space_before = Pt(8); ph.paragraph_format.space_after = Pt(2)
            pb = doc.add_paragraph(html_to_text(body)); 
            for rn in pb.runs: rn.font.size=Pt(10)

        section('Opis pliku', m['opis'])
        section('Ścieżka pliku', m['sciezka'])
        if m['uwagi']: section('Uwagi', m['uwagi'])
        section('Kontakt w przypadku awarii', m['kontakt'])

        # katalog stanów — pełny, dla każdego kodu (kafelki jak w oryginale)
        st = variant_for(code)
        if st:
            ph = doc.add_paragraph(); rh = ph.add_run(f'Katalog stanów kafelków ({len(st)} przypadków)')
            rh.bold=True; rh.font.size=Pt(10.5); rh.font.color.rgb=PSE_BLUE
            ph.paragraph_format.space_before = Pt(10)
            tbl = doc.add_table(rows=1, cols=4); set_borders(tbl)
            tbl.alignment = WD_TABLE_ALIGNMENT.LEFT
            heads = ['#','Stan kafelków','Opis stanu','Procedury awaryjne']
            widths = [Cm(0.8),Cm(3.8),Cm(5.0),Cm(7.2)]
            for j,hh in enumerate(heads):
                c = tbl.rows[0].cells[j]; c.text = hh; shade(c,'1F4E78')
                for p in c.paragraphs:
                    for rn in p.runs: rn.bold=True; rn.font.size=Pt(8.5); rn.font.color.rgb=RGBColor(255,255,255)
            for sst in st:
                cells = tbl.add_row().cells
                # #, opis, procedury — tekst
                txt = {0:str(sst.get('nr','')),
                       2:html_to_text(sst.get('opis_stanu','')),
                       3:html_to_text(sst.get('procedura',''))}
                for j,vv in txt.items():
                    cells[j].text = vv; cells[j].width = widths[j]
                    for p in cells[j].paragraphs:
                        p.paragraph_format.space_before=Pt(0); p.paragraph_format.space_after=Pt(0)
                        for rn in p.runs: rn.font.size=Pt(8)
                # Stan kafelków — kafelki obrazkowe z etykietą kolumny
                cell = cells[1]; cell.width = widths[1]
                pairs = parse_stan(sst.get('stan',''))
                first = True
                for col, clr in pairs:
                    para = cell.paragraphs[0] if first else cell.add_paragraph()
                    first = False
                    para.paragraph_format.space_before=Pt(0); para.paragraph_format.space_after=Pt(1)
                    rl = para.add_run(col + '  '); rl.font.size=Pt(7.5)
                    para.add_run().add_picture(str(tile_path(clr)), height=Pt(11))
        else:
            inf = doc.add_paragraph().add_run(
                'Dla tego pliku katalog stanów kafelków nie jest zdefiniowany odrębnie — '
                'monitorowanie zgodnie z profilem „' + m['profil'] + '" i procedurą główną (rozdz. 7–9).')
            inf.font.size = Pt(9); inf.italic=True; inf.font.color.rgb=RGBColor(0x66,0x66,0x66)

        if ci != len(ANCHORS)-1:
            doc.add_paragraph().add_run().add_break(WD_BREAK.PAGE)

    out = CCM/'edytowalny-info.docx'
    doc.save(str(out))
    print(f'DOCX: {out}  ({out.stat().st_size:,} B, {len(ANCHORS)} kotwic)')

build_docx()


