import re as _re
def anchor_order():
    f = CCM/'anchors.txt'
    codes = [l.strip() for l in f.read_text(encoding='utf-8').splitlines() if l.strip()]
    # twarda walidacja: tylko litery/cyfry/podkreślenia (poprawna kotwica)
    bad = [c for c in codes if not _re.fullmatch(r'[A-Za-z0-9_]+', c)]
    if bad:
        raise ValueError(f'Niepoprawne kotwice w anchors.txt: {bad[:5]}')
    return codes

