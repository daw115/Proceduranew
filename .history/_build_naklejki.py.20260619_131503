# 3) Named destinations w info.pdf (żeby info.pdf#KOD działało w przeglądarce)
# ═══════════════════════════════════════════════════════════════════════════
def add_named_dests():
    from pypdf import PdfReader, PdfWriter
    src = CCM/'info.pdf'
    r = PdfReader(str(src))
    w = PdfWriter(clone_from=str(src))
    added = 0
    for item in r.outline:
        if isinstance(item, list):  # zagnieżdżenia (brak) — pomiń
            continue
        code = item.title
        pg = r.get_destination_page_number(item)
        w.add_named_destination(code, pg)
        added += 1
    with open(src, 'wb') as f:
        w.write(f)
    # weryfikacja
    chk = PdfReader(str(src)).named_destinations
    print(f'Named destinations dodane: {added} | w pliku: {len(chk)}')
    for t in ['FID1_831','PERUN_ID3_ATC','XID_RA','RAP_PERUN_ID3','FID3C_710']:
        print(f'   #{t:16} {"OK" if t in chk else "BRAK"}')

add_named_dests()
