    'puste':           ('#FFFFFF', '',  '#42526E', '#DFE1E6'),
}
TILES_DIR = ROOT / 'img_ccm' / 'tiles'

def _gen_tiles():
    """Generuje kafelki PNG 1:1 z oryginalnej instrukcji."""
    from PIL import Image, ImageDraw, ImageFont
    TILES_DIR.mkdir(parents=True, exist_ok=True)
    SCALE, W, H, R = 6, 30, 30, 7
    def hx(c): return tuple(int(c[i:i+2],16) for i in (1,3,5))
    fp = None
    for cand in ['/System/Library/Fonts/Supplemental/Arial Bold.ttf',
                 '/Library/Fonts/Arial Bold.ttf']:
        if Path(cand).exists(): fp = cand; break
    paths = {}
    for key,(fill,mark,mcol,border) in TILE_SPEC.items():
        w,h = W*SCALE, H*SCALE
        im = Image.new('RGBA',(w,h),(0,0,0,0)); d = ImageDraw.Draw(im)
        bcol = hx(border) if border else hx(fill)
        d.rounded_rectangle([SCALE,SCALE,w-SCALE,h-SCALE], radius=R*SCALE,
                            fill=hx(fill), outline=bcol, width=(2*SCALE if border else 1))
        if mark and fp:
            fnt = ImageFont.truetype(fp, int(15*SCALE))
            tb = d.textbbox((0,0), mark, font=fnt)
            d.text(((w-(tb[2]-tb[0]))/2 - tb[0], (h-(tb[3]-tb[1]))/2 - tb[1]),
                   mark, font=fnt, fill=hx(mcol))
        im = im.resize((W,H), Image.LANCZOS)
        safe = key.replace(' ','_').replace('!','excl').replace('?','q')
        out = TILES_DIR/f'{safe}.png'; im.save(out)
        paths[key] = out
    return paths

TILE_PATHS = _gen_tiles()

def tile_path(color):
    """Ścieżka kafelka dla wartości koloru (z fallbackiem na 'puste')."""
    return TILE_PATHS.get((color or '').strip(), TILE_PATHS['puste'])

def parse_stan(text):
    """'CCtool wysł.: zielony · MinIO: szary' → [('CCtool wysł.','zielony'), ...]"""
    out = []
    for part in re.split(r'\s*·\s*', (text or '').strip()):
        if ':' in part:
            col, clr = part.split(':', 1)
            out.append((col.strip(), clr.strip()))
    return out

