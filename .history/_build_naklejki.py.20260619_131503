class Anchor(Flowable):
    """Rejestruje named destination = key na bieżącej stronie + wpis do outline."""
    def __init__(self, key, title, level=0):
        super().__init__(); self.key=key; self.title=title; self.level=level
        self.width=0; self.height=0
    def draw(self):
        self.canv.bookmarkPage(self.key)               # named destination = key
        self.canv.addOutlineEntry(self.title, self.key, self.level, closed=(self.level>0))

def p(txt, style):
    raw = txt if txt else '&nbsp;'
    try:
        return Paragraph(raw, style)
    except Exception:
        # fallback: pełne escape'owanie (gdy markup zawiera nielegalne znaki)
        safe = htmlmod.escape(_re.sub(r'<[^>]+>', '', raw))
        return Paragraph(safe or '&nbsp;', style)

def build_pdf():
    out = CCM/'info.pdf'
    doc = BaseDocTemplate(str(out), pagesize=A4,
                          leftMargin=1.6*cm, rightMargin=1.6*cm,
                          topMargin=1.5*cm, bottomMargin=1.5*cm,
                          title='CCM — info.pdf (naklejki IDCC)')
    frame = Frame(doc.leftMargin, doc.bottomMargin,
                  doc.width, doc.height, id='F')

    def footer(canv, d):
        canv.saveState()
        canv.setFont(FONT, 7)
        canv.setFillColor(GREY)
        canv.drawString(doc.leftMargin, 1.0*cm,
                        'Klasyfikacja: Informacja służbowa GK PSE / GK PSE Confidential')
        canv.drawRightString(A4[0]-doc.rightMargin, 1.0*cm, 'info.pdf')
        canv.restoreState()

    doc.addPageTemplates([PageTemplate(id='main', frames=[frame], onPage=footer)])

    flow = []
    # strona tytułowa + spis kotwic
    flow.append(p('CCM — Naklejki informacyjne IDCC', st_h1))
    flow.append(p('Załącznik <b>info.pdf</b> — opis plików i katalog stanów kafelków. '
                  'Linkowanie z popupów CCM: <b>/assets/info.pdf#KOD</b> '
                  '(np. info.pdf#FID1_831). Kotwice używają podkreśleń.', st_body))
    flow.append(Spacer(1, 6))
    flow.append(p('Spis kotwic (' + str(len(ANCHORS)) + ')', st_sech))
    # spis w 3 kolumnach z linkami wewnętrznymi
    per = (len(ANCHORS)+2)//3
    cols = [ANCHORS[i:i+per] for i in range(0, len(ANCHORS), per)]
    maxr = max(len(c) for c in cols)
    rows = []
    for r in range(maxr):
        row = []
        for c in cols:
            if r < len(c):
                code = c[r]
                row.append(p(f'<a href="#{code}" color="#1F4E78">{code}</a>', st_toc))
            else:
                row.append('')
        rows.append(row)
    toc = Table(rows, colWidths=[doc.width/3.0]*3)
    toc.setStyle(TableStyle([('VALIGN',(0,0),(-1,-1),'TOP'),
                             ('TOPPADDING',(0,0),(-1,-1),1),
                             ('BOTTOMPADDING',(0,0),(-1,-1),1)]))
    flow.append(toc)
    flow.append(PageBreak())

    for ci, code in enumerate(ANCHORS):
        m = meta(code)
        flow.append(Anchor(code, code, level=0))
        flow.append(p(code, st_h1))
        flow.append(p(f'{htmlmod.escape(m["nazwa"])} — {htmlmod.escape(m["obszar"])}', st_sub))

        # meta tabela
        mrow_h = [p('Profil',st_cellh),p('Target End Time',st_cellh),
                  p('Critical End Time',st_cellh),p('Wersja',st_cellh),p('Źródło',st_cellh)]
        mrow_v = [p(htmlmod.escape(str(m['profil'])),st_cell),p(htmlmod.escape(str(m['tet'])),st_cell),
                  p(htmlmod.escape(str(m['cet'])),st_cell),p(htmlmod.escape(str(m['wersja'])),st_cell),
                  p(htmlmod.escape(str(m['zrodlo'])),st_cell)]
        mt = Table([mrow_h, mrow_v], colWidths=[doc.width*x for x in (0.16,0.22,0.22,0.12,0.28)])
        mt.setStyle(TableStyle([
            ('BACKGROUND',(0,0),(-1,0),BLUE),
            ('GRID',(0,0),(-1,-1),0.4,colors.HexColor('#A8B8C8')),
            ('VALIGN',(0,0),(-1,-1),'MIDDLE'),
            ('TOPPADDING',(0,0),(-1,-1),3),('BOTTOMPADDING',(0,0),(-1,-1),3),
            ('LEFTPADDING',(0,0),(-1,-1),4),
        ]))
        flow.append(mt)

        def section(title, body):
            flow.append(p(title, st_sech))
            flow.append(p(html_to_rl(body) or '—', st_body))

        section('Opis pliku', m['opis'])
        section('Ścieżka pliku', m['sciezka'])
        if m['uwagi']: section('Uwagi', m['uwagi'])
        section('Kontakt w przypadku awarii', m['kontakt'])

        st = variant_for(code)
        if st:
            flow.append(p(f'Katalog stanów kafelków ({len(st)} przypadków)', st_sech))
            data = [[p('#',st_cellh),p('Stan kafelków',st_cellh),
                     p('Opis stanu',st_cellh),p('Procedury awaryjne',st_cellh)]]
            style = [
                ('BACKGROUND',(0,0),(-1,0),BLUE),
                ('GRID',(0,0),(-1,-1),0.4,colors.HexColor('#A8B8C8')),
                ('VALIGN',(0,0),(-1,-1),'TOP'),
                ('TOPPADDING',(0,0),(-1,-1),2),('BOTTOMPADDING',(0,0),(-1,-1),2),
                ('LEFTPADDING',(0,0),(-1,-1),3),('RIGHTPADDING',(0,0),(-1,-1),3),
                ('ROWBACKGROUNDS',(0,1),(-1,-1),[colors.white, colors.HexColor('#F4F7FB')]),
            ]
            for ri, sst in enumerate(st, start=1):
                data.append([
                    p(str(sst.get('nr','')), st_cell),
                    stan_cell(sst.get('stan','')),
                    p(html_to_rl(sst.get('opis_stanu','')), st_cell),
                    p(html_to_rl(sst.get('procedura','')), st_cell),
                ])
            tbl = Table(data, colWidths=[doc.width*x for x in (0.05,0.22,0.31,0.42)],
                        repeatRows=1)
            tbl.setStyle(TableStyle(style))
            flow.append(tbl)
        else:
            flow.append(p('Dla tego pliku katalog stanów kafelków nie jest zdefiniowany '
                          'odrębnie — monitorowanie zgodnie z profilem „' +
                          htmlmod.escape(m['profil']) + '" i procedurą główną (rozdz. 7–9).', st_note))

        if ci != len(ANCHORS)-1:
            flow.append(PageBreak())

    doc.build(flow)
    print(f'PDF:  {out}  ({out.stat().st_size:,} B, {len(ANCHORS)} named destinations)')

build_pdf()


