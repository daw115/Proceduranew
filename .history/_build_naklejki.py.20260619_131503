# ── konwersja HTML procedur → tekst / markup ───────────────────────────────
def html_to_text(s):
    if not s: return ''
    s = s.replace('&nbsp;', ' ')
    s = re.sub(r'<br\s*/?>', '\n', s, flags=re.I)
    s = re.sub(r'</(p|div|li)>', '\n', s, flags=re.I)
    s = re.sub(r'<li[^>]*>', '• ', s, flags=re.I)
    s = re.sub(r'<[^>]+>', '', s)
    s = htmlmod.unescape(s)
    s = re.sub(r'[ \t]+', ' ', s)
    s = re.sub(r'\n{3,}', '\n\n', s)
    return s.strip()

def html_to_rl(s):
    """HTML → markup akceptowany przez reportlab Paragraph (<b>,<i>,<br/>)."""
    if not s: return ''
    s = s.replace('&nbsp;', ' ')
    s = re.sub(r'<strong>', '<b>', s, flags=re.I)
    s = re.sub(r'</strong>', '</b>', s, flags=re.I)
    s = re.sub(r'<em>', '<i>', s, flags=re.I)
    s = re.sub(r'</em>', '</i>', s, flags=re.I)
    s = re.sub(r'<br\s*/?>', '<br/>', s, flags=re.I)
    s = re.sub(r'<li[^>]*>', '<br/>• ', s, flags=re.I)
    s = re.sub(r'</(p|div|ul|ol)>', '<br/>', s, flags=re.I)
    s = re.sub(r'<(?!/?(b|i|br|font)[ />])[^>]*>', '', s)  # usuń pozostałe tagi
    # napraw & (poza encjami)
    s = re.sub(r'&(?!amp;|lt;|gt;|#)', '&amp;', s)
    s = re.sub(r'(<br/>)+', '<br/>', s)
    s = re.sub(r'^(<br/>)+', '', s)
    return s.strip()

