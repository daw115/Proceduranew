FRAME_SECTIONS = ['Stan kafelków','Opis stanu kafelków','Procedury awaryjne',
                  'Kafelek MinIO / sFTP','Opis pliku','Ścieżka pliku',
                  'Kontakt w przypadku awarii']

def parse_frame(text):
    """Rozkłada 'pełną ramkę' stanu na pola."""
    if not text: return None
    text = text.replace('\r\n','\n')
    lines = text.split('\n')
    head = lines[0].strip()
    m = re.match(r'^(.*?)\s+—\s+Stan\s+(\d+)\s+·\s+([A-D])\s+—\s+(.*)$', head)
    rec = {'kod':'','nr':'','kat':'','nazwa':''}
    if m:
        rec.update(kod=m.group(1).strip(), nr=m.group(2),
                   kat=m.group(3), nazwa=m.group(4).strip())
    body = '\n'.join(lines[1:])
    idx = []
    for sec in FRAME_SECTIONS:
        for mm in re.finditer(r'(?m)^'+re.escape(sec)+r'\s*$', body):
            idx.append((mm.start(), mm.end(), sec))
    idx.sort()
    for i,(s,e,sec) in enumerate(idx):
        nxt = idx[i+1][0] if i+1 < len(idx) else len(body)
        rec[sec] = body[e:nxt].strip()
    return rec

def _load_states():
    wb = load_workbook(ROOT/'Stany_kafelkow_per_plik_IDCC.xlsx', data_only=True)
    by_anchor = {}
    extra = {}   # dodatkowe meta per kod: kanał MinIO/sFTP, nazwa
    for sh in STATE_SHEETS:
        prof = SHEET_PROFILE[sh]
        for r in wb[sh].iter_rows(min_row=2, values_only=True):
            if not (r and r[0]): continue
            rec = parse_frame(r[5])
            if not rec: continue
            anchor = norm(str(r[0]).strip())
            norm_rec = {
                'nr': rec.get('nr',''),
                'kategoria': rec.get('kat',''),
                'kategoria_nazwa': KAT_NAZWA.get(rec.get('kat',''),''),
                'stan': rec.get('Stan kafelków',''),
                'opis_stanu': rec.get('Opis stanu kafelków',''),
                'procedura': rec.get('Procedury awaryjne',''),
                'profil': prof,
            }
            by_anchor.setdefault(anchor, []).append(norm_rec)
            if anchor not in extra:
                extra[anchor] = {
                    'profil': prof,
                    'nazwa': rec.get('nazwa',''),
                    'kanal': rec.get('Kafelek MinIO / sFTP',''),
                    'opis_pliku': rec.get('Opis pliku',''),
                    'sciezka': rec.get('Ścieżka pliku',''),
                    'kontakt': rec.get('Kontakt w przypadku awarii',''),
                }
    # sortuj stany po numerze
    for a in by_anchor:
        by_anchor[a].sort(key=lambda x: int(x['nr']) if str(x['nr']).isdigit() else 0)
    return by_anchor, extra

STATES_BY_ANCHOR, STATE_EXTRA = _load_states()

