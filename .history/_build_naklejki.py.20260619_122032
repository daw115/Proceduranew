    n = (name or '').lower(); k = (kod or '').lower()
    if 'puls' in n: return '#2e7d32'
    if 'ciemnozielon' in n: return '#1b5e20'
    if 'zielon' in n: return '#2e7d32'
    if 'czerwon' in n: return '#c62828'
    if 'pomarań' in n: return '#f57c00'
    if 'fiolet' in n: return '#7b1fa2'
    if 'czarny' in n: return '#000000'
    if 'szary' in n: return '#9e9e9e'
    return '#bdbdbd'

KAT_HEX = {'A':'#2e7d32','B':'#f57c00','C':'#c62828','D':'#7b1fa2'}

# ── meta kodu ──────────────────────────────────────────────────────────────
def meta(code):
    it = content_by.get(code, {})
    return {
        'nazwa': it.get('nazwa_przeplywu',''),
        'obszar': it.get('obszar',''),
        'profil': it.get('profil',''),
        'tet': it.get('target_end_time',''),
        'cet': it.get('critical_end_time',''),
        'wersja': it.get('wersja',''),
        'zrodlo': it.get('zrodlo',''),
        'opis': it.get('opis_pliku',''),
        'sciezka': it.get('sciezka_pliku',''),
        'kontakt': it.get('kontakt',''),
        'uwagi': it.get('uwagi',''),
    }

print(f'Kotwic: {len(ANCHORS)} | z katalogiem stanów: '
      f'{sum(1 for c in ANCHORS if variant_for(c))}')
