"""Buduje 'naklejki' CCM w formie info.pdf + edytowalny-info.docx.

Każdy z 71 kodów = jedna kotwica (nagłówek = KOD z podkreśleniami) → strona z:
  - meta (profil, TET, CET, wersja, źródło)
  - Opis pliku / Ścieżka pliku / Kontakt
  - Pełny katalog stanów kafelków (dla profilu 2CCT: AC / GLSK-CBCORA / 928)

Wyjścia:
  CCM/edytowalny-info.docx   — master edytowalny (Heading = kotwica + zakładka Word)
  CCM/info.pdf               — named destinations = KOD (info.pdf#FID1_831 działa)

Kolejność kotwic = bieżąca kolejność stron w CCM/info.pdf (zachowana).
"""
import json, re, html as htmlmod, subprocess
from pathlib import Path

ROOT = Path('/Volumes/SSD/CLAUDE_WORK/Procedura')
CCM  = ROOT / 'CCM'

# ── kolejność kotwic z istniejącego info.pdf ───────────────────────────────
def anchor_order():
    out = subprocess.run(['pdftotext', str(CCM/'info.pdf'), '-'],
                         capture_output=True, text=True).stdout
    return [l.strip() for l in out.splitlines()
            if l.strip() and 'Klasyfikacja' not in l]

ANCHORS = anchor_order()

# ── dane źródłowe ──────────────────────────────────────────────────────────
content = json.load(open(ROOT/'popup_content_IDCC.json', encoding='utf-8'))
states  = json.load(open(ROOT/'popup_states_IDCC.json', encoding='utf-8'))

def norm(s): return s.replace('-', '_').strip()

# content: pierwsza (najbogatsza) pozycja per znormalizowany kod
content_by = {}
for it in content:
    k = norm(it['kod'])
    if k not in content_by:
        content_by[k] = it

# stany per wariant
states_by_variant = {}
for s in states:
    states_by_variant.setdefault(s['wariant'], []).append(s)

AC      = '2CCT — AC (źródło ZP)'
GLSKCB  = '2CCT — GLSK/CBCORA (źródło Kreator)'
V928    = '928 — ATC Based Validation (zwrotny)'

def variant_for(code):
    """Zwraca listę stanów dla kodu lub None."""
    if code.endswith('_831'):                         return states_by_variant.get(AC)
    if code.endswith('_607') or code.endswith('_617'):return states_by_variant.get(GLSKCB)
    if code.endswith('_928'):                         return states_by_variant.get(V928)
    return None

# ── konwersja HTML procedur → tekst / markup ───────────────────────────────
def html_to_text(s):
    if not s: return ''
    s = s.replace('&nbsp;', ' ')
    s = re.sub(r'<br\s*/?>', '\n', s, flags=re.I)
    s = re.sub(r'</(p|div|li)>', '\n', s, flags=re.I)
    s = re.sub(r'<li[^>]*>', '• ', s, flags=re.I)
    s = re.sub(r'<[^>]+>', '', s)
    s = htmlmod.unescape(s)
    s = re.sub(r'[ \t]+', ' ', s)
    s = re.sub(r'\n{3,}', '\n\n', s)
    return s.strip()

def html_to_rl(s):
    """HTML → markup akceptowany przez reportlab Paragraph (<b>,<i>,<br/>)."""
    if not s: return ''
    s = s.replace('&nbsp;', ' ')
    s = re.sub(r'<strong>', '<b>', s, flags=re.I)
    s = re.sub(r'</strong>', '</b>', s, flags=re.I)
    s = re.sub(r'<em>', '<i>', s, flags=re.I)
    s = re.sub(r'</em>', '</i>', s, flags=re.I)
    s = re.sub(r'<br\s*/?>', '<br/>', s, flags=re.I)
    s = re.sub(r'<li[^>]*>', '<br/>• ', s, flags=re.I)
    s = re.sub(r'</(p|div|ul|ol)>', '<br/>', s, flags=re.I)
    s = re.sub(r'<(?!/?(b|i|br|font)[ />])[^>]*>', '', s)  # usuń pozostałe tagi
    # napraw & (poza encjami)
    s = re.sub(r'&(?!amp;|lt;|gt;|#)', '&amp;', s)
    s = re.sub(r'(<br/>)+', '<br/>', s)
    s = re.sub(r'^(<br/>)+', '', s)
    return s.strip()

# kolory kafelków
TILE_HEX = {
    'ziel':'#2e7d32','ziel_R':'#2e7d32','ziel_W':'#1b5e20','ziel_puls':'#2e7d32',
    'pomar':'#f57c00','czerw':'#c62828','czerw_q':'#c62828','czerw_excl':'#c62828',
    'fiolet':'#7b1fa2','czarny':'#000000','szary':'#9e9e9e','szary_q':'#9e9e9e',
    'biale':'#ffffff','puste':'#ffffff',
}
